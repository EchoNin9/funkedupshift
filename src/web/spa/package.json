{
  "name": "funkedupshift-spa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "predev": "cp node_modules/amazon-cognito-identity-js/dist/amazon-cognito-identity.min.js public/",
    "build": "vite build",
    "prebuild": "cp node_modules/amazon-cognito-identity-js/dist/amazon-cognito-identity.min.js public/",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build:mobile": "cp ../auth.js public/auth.js 2>/dev/null || true && npm run build && npx cap sync",
    "build:mobile:prod": "node scripts/write-mobile-config.js && npm run build:mobile"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.5",
    "framer-motion": "^11.11.17",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "amazon-cognito-identity-js": "^6.3.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.1.0"
  }
}

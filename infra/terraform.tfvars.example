# Copy to terraform.tfvars and set values.
# terraform.tfvars is typically not committed (add to .gitignore if desired).

awsRegion     = "us-east-1"
githubOrgRepo = "EchoNin9/funkedupshift"

# For local runs with a named profile: export AWS_PROFILE=echo9 before terraform

# Optional overrides for state backend (defaults in variables.tf)
terraformStateBucket     = "fus-aws-s3-terraform-state"
terraformStateLockTable  = "fus-terraform-state-lock"

# Personal Finances app (all optional; features stay dark until set)
eraApiKey      = ""  # Era.app key — enables read-only Era account/transaction sync
mcpBearerToken = ""  # long random secret; required for the finances MCP endpoint
mcpOwnerUserId = ""  # Cognito sub whose finances the MCP server exposes
